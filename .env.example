# Desarrollo local (recomendado — requiere proxy en vite.config.js):
VITE_API_URL=/api

# Sin proxy (cross-origin, CSRF suele fallar entre :5173 y :8000):
# VITE_API_PROTOCOL=http
# VITE_API_DOMAIN=localhost
# VITE_API_PORT=8000

# Producción (Render):
# VITE_API_URL=https://gol-ahora-backend-1.onrender.com/api
